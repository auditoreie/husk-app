{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Husk",
  "version": "0.1.0",
  "identifier": "dev.gethusk.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Husk",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Lightweight service aggregator",
    "longDescription": "Husk is a lightweight service aggregator. Run multiple web services as isolated webviews in a single native shell. No Electron, no bloat.",
    "copyright": "Copyright 2026 Auditore",
    "publisher": "Auditore",
    "homepage": "https://gethusk.dev",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
